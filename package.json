{
  "name": "shaxda",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter @shaxda/web dev",
    "dev:worker": "pnpm --filter @shaxda/worker dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "lint:staged": "lint-staged",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "vitest --watch",
    "test:worker": "turbo run test:worker",
    "test:e2e": "playwright test",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "prepare": "node scripts/install-git-hooks.mjs"
  },
  "lint-staged": {
    "*.{cjs,js,mjs,ts,svelte}": [
      "eslint --fix",
      "prettier --write --ignore-unknown"
    ],
    "*.{css,json,md,toml,yaml,yml}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@types/node": "^22.15.3",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-svelte": "^3.9.0",
    "globals": "^16.3.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte-eslint-parser": "^1.2.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^4.1.9"
  }
}
