{
  "name": "@shaxda/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "assets:all": "pnpm assets:audio && pnpm assets:icons",
    "assets:audio": "node scripts/generate-audio.mjs",
    "assets:icons": "node scripts/generate-icons.mjs",
    "build": "vite build",
    "dev": "vite dev",
    "format": "prettier --write .",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@lucide/svelte": "^1.23.0",
    "@shaxda/game-engine": "workspace:*",
    "@shaxda/i18n": "workspace:*",
    "@shaxda/shared": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/kit": "^2.69.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.4.2",
    "@vite-pwa/sveltekit": "^1.1.0",
    "bits-ui": "^2.18.1",
    "jsdom": "^29.1.1",
    "shadcn-svelte": "^1.3.0",
    "svelte": "^5.56.4",
    "svelte-check": "^4.7.1",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
